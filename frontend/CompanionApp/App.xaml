<Application x:Class="CompanionApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFF5EEE8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FFD08770" />
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FFF9F3EE" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF342C28" />
        </Style>
    </Application.Resources>
</Application>
