<Window x:Class="CompanionApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sefai Companion"
        Width="1200"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.4*" />
            <ColumnDefinition Width="1.15*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="22" CornerRadius="22" Background="{StaticResource PanelBrush}" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock x:Name="CompanionNameTextBlock" FontSize="30" FontWeight="SemiBold" Text="Aria" />
                        <TextBlock x:Name="StatusTextBlock" Margin="0,4,0,0" Opacity="0.75" Text="Resident and listening" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Width="96" Height="34" Margin="0,0,10,0" Click="Settings_Click" Content="Settings" />
                        <Button Width="128" Height="34" Click="PauseAutonomy_Click" Content="Pause Autonomy" />
                    </StackPanel>
                </DockPanel>

                <ListBox x:Name="ChatListBox" Grid.Row="1" Margin="0,20,0,20" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="16" Margin="0,0,0,12" CornerRadius="16" Background="#FFFDF8F5">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Speaker}" />
                                        <Border DockPanel.Dock="Right" Background="{Binding AccentBrush}" CornerRadius="10" Padding="8,2" Margin="12,0,0,0">
                                            <TextBlock Foreground="White" FontSize="11" Text="{Binding DeliveryTag}" />
                                        </Border>
                                    </DockPanel>
                                    <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Text="{Binding Content}" />
                                    <TextBlock Margin="0,10,0,0" FontSize="11" Opacity="0.6" Text="{Binding Timestamp}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox x:Name="ChatInputTextBox"
                             Height="96"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="15"
                             Padding="14" />
                    <DockPanel Grid.Row="1" Margin="0,12,0,0">
                        <TextBlock x:Name="ComposerHintTextBlock"
                                   VerticalAlignment="Center"
                                   Opacity="0.65"
                                   Text="Ask something substantive. The companion can refuse shallow prompts." />
                        <Button Width="96" Height="40" HorizontalAlignment="Right" DockPanel.Dock="Right" Click="Send_Click" Content="Send" />
                    </DockPanel>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Column="1">
            <Border Padding="20" CornerRadius="22" Background="{StaticResource PanelBrush}">
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="Presence" />
                    <TextBlock Margin="0,16,0,4" FontWeight="SemiBold" Text="Mood" />
                    <TextBlock x:Name="MoodTextBlock" FontSize="18" Text="Engaged" />
                    <TextBlock Margin="0,16,0,4" FontWeight="SemiBold" Text="Relationship Summary" />
                    <TextBlock x:Name="RelationshipSummaryTextBlock" TextWrapping="Wrap" />
                    <TextBlock Margin="0,16,0,4" FontWeight="SemiBold" Text="Active Goals" />
                    <ItemsControl x:Name="GoalsItemsControl" />
                </StackPanel>
            </Border>

            <Border Margin="0,16,0,16" Padding="20" CornerRadius="22" Background="{StaticResource PanelBrush}">
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="Timeline" />
                    <TextBlock Margin="0,12,0,8" Opacity="0.75" Text="Autonomous check-ins and notable moments appear here as they persist." />
                    <ListBox x:Name="TimelineListBox" MinHeight="180" BorderThickness="0" Background="Transparent" />
                </StackPanel>
            </Border>

            <Border Padding="20" CornerRadius="22" Background="{StaticResource PanelBrush}">
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="Runtime" />
                    <TextBlock x:Name="RuntimeTextBlock" Margin="0,12,0,0" Text="Backend: starting..." />
                    <TextBlock x:Name="ModelPathTextBlock" Margin="0,8,0,0" TextWrapping="Wrap" />
                    <TextBlock x:Name="QuietModeTextBlock" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
