<Window x:Class="CompanionApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Companion Settings"
        Width="520"
        Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock FontSize="26" FontWeight="SemiBold" Text="Settings" />
            <Border Margin="0,20,0,0" Padding="18" Background="{StaticResource PanelBrush}" CornerRadius="16">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Model path" />
                    <TextBox x:Name="ModelPathTextBox" Margin="0,8,0,16" Height="32" />
                    <TextBlock FontWeight="SemiBold" Text="Persona path" />
                    <TextBox x:Name="PersonaPathTextBox" Margin="0,8,0,16" Height="32" />
                    <TextBlock FontWeight="SemiBold" Text="Context size" />
                    <TextBox x:Name="ContextSizeTextBox" Margin="0,8,0,16" Height="32" />
                    <TextBlock FontWeight="SemiBold" Text="Thread count" />
                    <TextBox x:Name="ThreadCountTextBox" Margin="0,8,0,16" Height="32" />
                    <TextBlock FontWeight="SemiBold" Text="GPU layers" />
                    <TextBox x:Name="GpuLayersTextBox" Margin="0,8,0,16" Height="32" />
                    <TextBlock FontWeight="SemiBold" Text="Temperature" />
                    <TextBox x:Name="TemperatureTextBox" Margin="0,8,0,16" Height="32" />
                    <TextBlock FontWeight="SemiBold" Text="Top P" />
                    <TextBox x:Name="TopPTextBox" Margin="0,8,0,16" Height="32" />
                    <CheckBox x:Name="AutonomyCheckBox" Content="Autonomy enabled" Margin="0,0,0,10" />
                    <CheckBox x:Name="StartupCheckBox" Content="Launch at sign-in" Margin="0,0,0,10" />
                    <CheckBox x:Name="NotificationsCheckBox" Content="Notifications enabled" Margin="0,0,0,10" />
                    <CheckBox x:Name="QuietModeCheckBox" Content="Quiet mode" />
                </StackPanel>
            </Border>
            <Button Margin="0,20,0,0" Width="120" Height="36" HorizontalAlignment="Right" Click="Save_Click" Content="Save" />
        </StackPanel>
    </ScrollViewer>
</Window>
